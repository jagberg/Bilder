---
import Layout from '../layouts/Layout.astro';
import LikeButton from '../components/LikeButton.astro';
export const prerender = true;

const faq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Is Hebel cheaper than brick?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Hebel is typically priced like-for-like with brick veneer — most builders let you swap between the two at no cost difference. It's noticeably cheaper on first-floor walls that don't line up over a wall below, because brick would need steel support there while Hebel doesn't.",
      },
    },
    {
      '@type': 'Question',
      name: 'Does Hebel insulate better than brick?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — as a full wall system (panel plus insulated frame), Hebel offers almost three times the thermal benefit of brick. The Hebel PowerPanelXL panel on its own is R0.52; EPS panels like NRG Greenboard rate higher at R1.95 to R3.31 per panel and are the strongest thermal choice among render-look cladings. Fibre-cement cladding on its own provides almost no thermal insulation; its R-value comes from the insulation behind the panels.',
      },
    },
    {
      '@type': 'Question',
      name: "What's the difference between extruded and dry-pressed bricks?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Extruded bricks have holes through them, making them lighter (~3.1kg each) and cheaper to both manufacture and lay — colour is typically coated or glazed on the surface. Dry-pressed bricks are solid (~3.4kg each), colour runs through the brick, and they cost more to buy and more to lay because they are heavier and slower to place.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is EPS cladding allowed in Victoria?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'EPS is prohibited from use in certain types of buildings in Victoria and may impact house insurance costs. Product rating (up to BAL-29 for some EPS products) and building type determine whether EPS is acceptable — confirm with your builder and local regulations before specifying it.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do I need to repaint a rendered house?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes — rendered walls typically need repainting every few years as paint discolours or stains, and hairline cracks may need patching. Face brick doesn\u2019t need repainting, just occasional cleaning, which makes it the lowest-maintenance external finish.',
      },
    },
    {
      '@type': 'Question',
      name: 'Do cladding panels provide thermal insulation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cladding panels by themselves provide very little thermal insulation. The wall\u2019s R-value comes from the insulation batts and batten cavity behind the cladding, not the cladding itself — expect almost zero thermal benefit from the panels alone.',
      },
    },
  ],
};
---

<Layout
  title="Hebel vs Brick vs Cladding: Cost, Thermal & Maintenance Compared"
  description="Side-by-side comparison of brick veneer, Hebel, EPS, render and James Hardie cladding — R-ratings, real prices per m², and the maintenance trade-offs for Australian builds."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faq)} />

  <LikeButton slug="brick-cladding-hebel-or-otherwise" />

  <div class="bcw">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
      <a href="/">Home</a> &rsaquo; <span>Building Materials</span> &rsaquo; <span>Brick, Cladding &amp; Hebel</span>
    </div>

    <!-- Page header -->
    <div class="bcw-header">
      <h1>Hebel vs Brick vs Cladding</h1>
      <p class="bcw-lead">Cost, thermal &amp; maintenance compared for Australian builds — brick veneer, Hebel, EPS, render and James Hardie cladding, side-by-side.</p>
      <div class="bcw-meta">
        <span>6 materials compared</span>
        <span class="sep">·</span>
        <span>Last updated 19 April 2026</span>
      </div>
    </div>

    <!-- Intro -->
    <div class="intro-box">
      <p><strong>Hebel vs brick vs cladding</strong> — the three external wall options almost every Australian new-build chooses between, plus the rendered alternatives (EPS, Blueboard) that sit in the middle. This guide covers look, cost, thermal and acoustic performance, and real maintenance trade-offs. Double brick walls are excluded. A good companion write-up: <a href="https://forsyth35.com/2018/05/06/hebel-vs-brick/" target="_blank" rel="noopener">Forsyth — Hebel vs Brick</a>.</p>
    </div>

    <!-- Table of Contents -->
    <nav class="toc-card" id="page-toc" aria-label="Table of contents">
      <div class="toc-card-head">
        <span class="toc-card-title">Contents</span>
        <button class="toc-toggle" aria-expanded="true">[hide]</button>
      </div>
      <div class="toc-body" id="toc-body">
        <div class="toc-group">
          <div class="toc-group-label">Brick</div>
          <ul>
            <li><a href="#brick-veneer">Brick Veneer / Facebrick</a></li>
          </ul>
        </div>
        <div class="toc-group">
          <div class="toc-group-label">Render</div>
          <ul>
            <li><a href="#rendered-bricks">Rendered Bricks</a></li>
            <li><a href="#hebel">Hebel PowerPanel</a></li>
            <li><a href="#eps">EPS</a></li>
            <li><a href="#blueboard">Blueboard Fine Texture</a></li>
          </ul>
        </div>
        <div class="toc-group">
          <div class="toc-group-label">Cladding</div>
          <ul>
            <li><a href="#scyon">James Hardie Scyon</a></li>
            <li><a href="#matrix">James Hardie Matrix</a></li>
          </ul>
        </div>
        <div class="toc-group">
          <div class="toc-group-label">Performance</div>
          <ul>
            <li><a href="#thermal-acoustic">Thermal &amp; Acoustic</a></li>
            <li><a href="#maintenance">Maintenance</a></li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Key Takeaways -->
    <div class="takeaways">
      <div class="takeaways-title">Key Takeaways</div>
      <ul>
        <li><strong>Builders usually swap brick veneer for Hebel at no extra cost.</strong> Hebel is a like-for-like cost comparison to brick veneer and most builders will let you choose between either with no price difference.</li>
        <li><strong>Face brick is the lowest-maintenance finish.</strong> No repainting — just occasional cleaning. Rendered and cladded walls typically need repainting every few years and may need cracks patched or caulking refreshed.</li>
        <li><strong>Hebel (system) delivers almost 3× the thermal benefit of brick — but EPS panels beat Hebel per panel.</strong> NRG Greenboard EPS is R1.95–3.31 per panel vs Hebel PowerPanelXL 75mm at R0.52. Fibre-cement cladding on its own is near zero — R-value comes from the cavity and insulation behind it.</li>
        <li><strong>Upgrading from standard bricks to a premium range can add $5–45k on a double storey.</strong> Retail pricing is misleading — call Austral or PGH for the price on 20,000 bricks to see what a builder actually pays.</li>
        <li><strong>EPS cladding is banned in certain Victorian buildings and may affect insurance.</strong> Investigate with your builder before specifying it — this varies by state and product rating.</li>
      </ul>
    </div>

    <!-- At a glance -->
    <div class="at-a-glance">
      <div class="at-a-glance-head">At a glance</div>
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr>
              <th>Material</th>
              <th>Cost tier</th>
              <th>Thermal</th>
              <th>Acoustic</th>
              <th>Maintenance</th>
            </tr>
          </thead>
          <tbody>
            <tr><td><strong>Face brick</strong></td><td>Baseline</td><td>Standard</td><td>Good</td><td>Very low — no repaint</td></tr>
            <tr><td><strong>Hebel PowerPanel</strong></td><td>≈ Face brick</td><td>Panel R0.52 · ~3× brick as a system</td><td>Good (panel + frame)</td><td>Repaint every few years</td></tr>
            <tr><td><strong>Rendered brick</strong></td><td>Higher (brick + render)</td><td>Standard</td><td>Good</td><td>Repaint + crack patching</td></tr>
            <tr><td><strong>EPS (NRG Greenboard)</strong></td><td>Mid</td><td><strong>Best render-look option — R1.95–3.31</strong></td><td>OK (Rw 37–39 system)</td><td>Easier/cheaper to patch than Hebel. <strong>Vic: restricted</strong></td></tr>
            <tr><td><strong>Blueboard / Fine Texture</strong></td><td>Mid</td><td>Low</td><td>Low</td><td>Paint-ready — repaint cycles</td></tr>
            <tr><td><strong>Cladding (Scyon / Matrix)</strong></td><td>Lower</td><td>Near zero on its own</td><td>Low</td><td>Repaint + caulking refresh</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ═══════════════════════════════════════
         BRICK
    ═══════════════════════════════════════ -->
    <section>
      <div class="section-label">Brick</div>

      <!-- Brick Veneer / Facebrick -->
      <div class="card" id="brick-veneer">
        <div class="card-head">
          <h3>Brick Veneer / Facebrick</h3>
          <span class="badge-neutral">Most common</span>
        </div>
        <div class="card-body">
          <p>Brick veneer is a single brick course on the outside with a timber or steel frame on the inside. Facebricks are more expensive than common bricks and laying them requires more care to keep courses straight and neat. Once laid, the wall is typically cleaned with an acid wash.</p>

          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">Face brick</div>
              <figure><img src="/images/brick-cladding-hebel-or-otherwise/face-brick.png" alt="Face brick" loading="lazy"></figure>
            </div>
            <div class="compare-col">
              <div class="compare-label">Steel frame with brick veneer</div>
              <figure><img src="/images/brick-cladding-hebel-or-otherwise/steel-frame-brick-veneer.png" alt="Steel frame and brick veneer" loading="lazy"></figure>
            </div>
          </div>

          <h4 class="sub-head">Austral &amp; PGH — how the pricing actually works</h4>
          <p>Austral and PGH are the most used brick suppliers among NSW builders and most have discounted supply contracts for certain ranges. Upgrading to a premium range can add several thousand dollars.</p>

          <div class="cost-list">
            <div class="cost-row">
              <span class="cost-label">Austral Wilderness (incl. Blue Gum) — standard inclusion</span>
              <span class="cost-value">Retail $1,952 / 1000 · Builder ~$1,000 / 1000</span>
            </div>
            <div class="cost-row">
              <span class="cost-label">Austral San Selmo Reclaimed — premium</span>
              <span class="cost-value">Retail $3,000 / 1000</span>
            </div>
            <div class="cost-row">
              <span class="cost-label">Upgrade cost on a double storey</span>
              <span class="cost-value">+$5–45k depending on coverage</span>
            </div>
          </div>

          <div class="box-tip">
            <strong>Get the real price, not retail.</strong> Discounts on non-standard bricks are much smaller than on standard ranges, so retail-to-retail comparisons are misleading. Call Austral or PGH and ask for the price on ~20,000 bricks to see what the builder is actually paying.
          </div>

          <h4 class="sub-head">Extruded vs Dry Pressed</h4>
          <p>Extruded and dry-pressed bricks look similar once laid, but they behave very differently on the builder's invoice — both in the brick itself and in the labour to lay it.</p>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>&nbsp;</th>
                  <th>Extruded</th>
                  <th>Dry Pressed</th>
                </tr>
              </thead>
              <tbody>
                <tr><td><strong>Weight</strong></td><td>~3.1 kg each</td><td>~3.4 kg each (~10% heavier)</td></tr>
                <tr><td><strong>Perforations</strong></td><td>Hollow — holes through the brick</td><td>Solid — no holes</td></tr>
                <tr><td><strong>Colour</strong></td><td>Coated or glazed on the surface</td><td>Runs through the brick</td></tr>
                <tr><td><strong>If chipped</strong></td><td>Reddish base colour shows through</td><td>Barely visible — same colour underneath</td></tr>
                <tr><td><strong>Manufacturing</strong></td><td>Continuous extrusion — cheaper process</td><td>High-pressure moulding for dimensional accuracy</td></tr>
                <tr><td><strong>Material cost</strong></td><td>Standard</td><td>Premium</td></tr>
                <tr><td><strong>Laying cost</strong></td><td>Standard rate</td><td>Heavier &amp; slower to place — bricklayers typically charge more</td></tr>
              </tbody>
            </table>
          </div>

          <div class="box-tip">
            <strong>Why dry-pressed costs more to lay.</strong> Standard bricklayer productivity is roughly 500–1,000 bricks per day for straightforward work. Heavier, solid bricks sit at the lower end — they're more fatiguing to handle across a full day, and the tighter dimensional tolerance of a dry-pressed brick leaves less room for fudging a course. The labour premium stacks on top of the higher material cost, so a dry-pressed wall can cost meaningfully more than extruded once both are added together.
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         RENDER
    ═══════════════════════════════════════ -->
    <section>
      <div class="section-label">Render &amp; Rendered-Look Options</div>

      <div class="card">
        <div class="card-head">
          <h3>Is Hebel cheaper than brick?</h3>
        </div>
        <div class="card-body">
          <p><strong>Usually — they're priced like-for-like.</strong> Most builders will swap brick veneer for Hebel at no cost difference. Hebel is lighter, faster to install, and finished with acrylic render. It becomes noticeably cheaper than brick on first-floor walls that don't line up over a wall below — brick would need steel support there, while Hebel doesn't.</p>

          <p>Beyond Hebel, there are several ways to get a rendered look and the cost gap between them is often smaller than people expect. Alongside the options below there are other alternatives worth considering if a rendered finish is what you're after.</p>

          <div class="box-warn">
            <strong>Factor in maintenance.</strong> A face brick house doesn't require painting — just occasional cleaning. Render can stain over time, especially non-smooth finishes or walls without cappings.
          </div>
        </div>
      </div>

      <!-- Rendered Bricks -->
      <div class="card" id="rendered-bricks">
        <div class="card-head">
          <h3>Rendered Bricks</h3>
          <span class="badge-cost">+$25k render</span>
        </div>
        <div class="card-body">
          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">How it works</div>
              <p>Common extruded bricks are laid and then finished with an acrylic render. At the time of writing, Austral common bricks retail around <strong>$1,598 / 1000</strong>, and rendering the entire house can easily add another <strong>$25k</strong>.</p>
              <p>They are cheaper to lay than facebricks because render hides imperfections, but the added render cost usually makes the total significantly higher than facebrick.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">Extruded common brick</div>
              <figure><img src="http://cdn.shopify.com/s/files/1/0570/7471/2757/products/BRICKPHOTO_1024x1024.jpg?v=1624413150" alt="Extruded common bricks" loading="lazy"></figure>
            </div>
          </div>
        </div>
      </div>

      <!-- Hebel -->
      <div class="card" id="hebel">
        <div class="card-head">
          <h3>Hebel PowerPanel</h3>
          <span class="badge-cost">Often $0 vs brick veneer</span>
        </div>
        <div class="card-body">
          <p>Hebel is a lightweight aerated concrete that's been around for over 50 years (originally invented in Germany). It's quick to install and is a cheaper alternative to rendered brick. Hebel is often a like-for-like cost comparison to brick veneer — many builders will let you choose between the two with no price difference.</p>

          <p>Hebel is also commonly used as a lightweight material for first floors, particularly where walls don't line up underneath. It's an alternative to cladding in that scenario — slightly more expensive than cladding but much cheaper than bricks (which would need steel support underneath). After installation, Hebel is finished with an acrylic render.</p>

          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">Common concerns (and fixes)</div>
              <ul>
                <li><strong>Chipping</strong> — can happen from knocks (e.g. mower bumps). Damage is patchable.</li>
                <li><strong>Cracking</strong> — usually caused by incorrect installation rather than the product itself.</li>
                <li><strong>Hanging heavy items</strong> — requires specific screws and fixing techniques.</li>
              </ul>
              <p>Hebel also has strong thermal and acoustic benefits — see the <a href="#thermal-acoustic">performance section</a>.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">Hebel PowerPanel (before render)</div>
              <figure><img src="https://forsyth35blog.files.wordpress.com/2018/05/hebel-wall.jpg?w=736" alt="Hebel PowerPanel before render" loading="lazy"></figure>
            </div>
          </div>
        </div>
      </div>

      <!-- EPS -->
      <div class="card" id="eps">
        <div class="card-head">
          <h3>EPS (Expanded Polystyrene)</h3>
          <span class="badge-cost">Best thermal of render options</span>
        </div>
        <div class="card-body">
          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">How it works</div>
              <p>Similar to Hebel in concept but made of high-density expanded polystyrene — a lightweight panel with acrylic render applied after installation. It's less prone to cracking than Hebel because polystyrene doesn't expand the same way, and certain products (like NRG Greenboard 75–100mm) are rated up to BAL-29.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">EPS (before render)</div>
              <figure><img src="https://theidealgroup.net.au/wp-content/uploads/photo-gallery/imported_from_media_libray/10-5.jpg" alt="EPS panels before render" loading="lazy"></figure>
            </div>
          </div>

          <div class="box-tip">
            <strong>EPS outperforms Hebel on thermal per panel.</strong> NRG Greenboard ranges from R1.95 (75mm direct fix) to R3.31 (100mm with batten cavity). Hebel PowerPanelXL 75mm sits at R0.52 on its own — Hebel's system-level thermal benefit comes from the panel <em>plus</em> an insulated wall frame. If thermal efficiency is the priority, EPS is the strongest render-look option. See the <a href="#thermal-acoustic">performance table</a> for full numbers.
          </div>

          <div class="box-warn">
            <strong>Victoria restrictions.</strong> <a href="https://www.minterellison.com/articles/victoria-prohibits-use-of-high-risk-cladding-products" target="_blank" rel="noopener">EPS is banned from use in certain types of buildings in Victoria</a>, which may also impact house insurance costs. Confirm with your builder whether this affects your build.
          </div>
        </div>
      </div>

      <!-- Blueboard / James Hardie Fine Texture -->
      <div class="card" id="blueboard">
        <div class="card-head">
          <h3>Blueboard / James Hardie Fine Texture Cladding</h3>
          <span class="badge-neutral">Paint-ready</span>
        </div>
        <div class="card-body">
          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">How it works</div>
              <p>A fibre cement board that doesn't offer the same structural, thermal or acoustic benefits as other materials. It comes pre-sealed and ready to paint — no render step required, which saves time and cost compared to Hebel PowerPanels and EPS.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">James Hardie Fine Texture</div>
              <figure><img src="/images/brick-cladding-hebel-or-otherwise/james-hardie-fine-texture-cladding.png" alt="James Hardie Fine Texture cladding" loading="lazy"></figure>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CLADDING
    ═══════════════════════════════════════ -->
    <section>
      <div class="section-label">Cladding</div>

      <div class="card">
        <div class="card-body">
          <p>Cladding products don't require rendering and just need to be painted. They install quickly with minimal mess compared to bricks or render systems.</p>

          <p>They are lightweight and on their own provide little thermal or acoustic performance. A house wrap (sarking) is required behind them to protect against moisture, dust and drafts. It isn't waterproof, and even the cladding itself allows some moisture to form behind it — the system is installed against battens so water drains down behind the panel onto the ground or a channel at the base.</p>

          <figure class="full-img">
            <img src="/images/brick-cladding-hebel-or-otherwise/stria-and-matrix-cladding.png" alt="James Hardie Stria and Matrix cladding" loading="lazy">
            <figcaption>James Hardie Stria (top) and Matrix (bottom) cladding</figcaption>
          </figure>
        </div>
      </div>

      <!-- Scyon -->
      <div class="card" id="scyon">
        <div class="card-head">
          <h3>James Hardie Scyon</h3>
        </div>
        <div class="card-body">
          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">How it works</div>
              <p>A fibre cement board installed by overlapping horizontally. Comes in various widths to suit different looks.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">Scyon profile</div>
              <figure><img src="/images/brick-cladding-hebel-or-otherwise/james-hardie-scyon.png" alt="James Hardie Scyon cladding" loading="lazy"></figure>
            </div>
          </div>
        </div>
      </div>

      <!-- Matrix -->
      <div class="card" id="matrix">
        <div class="card-head">
          <h3>James Hardie Matrix</h3>
        </div>
        <div class="card-body">
          <div class="compare-2">
            <div class="compare-col">
              <div class="compare-label">How it works</div>
              <p>Also comes in various sizes, but very different to Scyon — Matrix panels don't overlap, which means water ingress is easier (and expected by the system). Panels are glued onto a metal plate and nailed to the battens. James Hardie joint sealant is used to seal the gaps.</p>
            </div>
            <div class="compare-col">
              <div class="compare-label">Matrix profile</div>
              <figure><img src="/images/brick-cladding-hebel-or-otherwise/james-hardie-matrix.png" alt="James Hardie Matrix cladding" loading="lazy"></figure>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         THERMAL & ACOUSTIC
    ═══════════════════════════════════════ -->
    <section>
      <div class="section-label">Performance</div>

      <!-- Thermal & Acoustic -->
      <div class="card" id="thermal-acoustic">
        <div class="card-head">
          <h3>Does Hebel insulate better than brick?</h3>
        </div>
        <div class="card-body">
          <p><strong>Yes — Hebel as a system offers almost 3× the thermal benefit of brick.</strong> That figure is panel + insulated wall frame combined. The Hebel PowerPanelXL 75mm panel on its own is R0.52 — <strong>EPS (NRG Greenboard) ranges R1.95–3.31 per panel and is the strongest thermal option of the render-look cladings.</strong> Cladding like Scyon/Matrix on its own provides almost no thermal insulation — its R-value depends on the insulation and batten cavity behind the panels. Cladding also releases heat more quickly than brick, which can be an advantage in warmer climates.</p>

          <div class="box-info">
            <strong>House wrap (sarking) is a draft and moisture barrier, not insulation.</strong> It provides minimal thermal benefit directly — its role is moisture management (it's not waterproof), reducing drafts, and in fire-prone areas it's BAL-rated. By limiting drafts, it lets other thermally efficient materials do their job properly. Think of it like an umbrella in strong wind — by reducing the wind hitting you, the temperature feels warmer even though the umbrella isn't insulating you.
          </div>

          <figure class="full-img" style="max-width: 520px; margin-left: auto; margin-right: auto;">
            <a href="https://forsyth35.com/2018/05/06/hebel-vs-brick/" target="_blank" rel="noopener">
              <img src="https://forsyth35blog.files.wordpress.com/2018/04/screen-shot-2018-04-25-at-2-59-33-pm.png?w=736" alt="Material thermal comparison chart" loading="lazy">
            </a>
            <figcaption>Material thermal comparison (source: Forsyth)</figcaption>
          </figure>

          <h4 class="sub-head">NRG Greenboard vs Hebel PowerPanel</h4>
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Material</th>
                  <th>R rating (Thermal)</th>
                  <th>Rw (Acoustic)</th>
                  <th>Price (p/m²)</th>
                  <th>Weight (p/m²)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>NRG Greenboard — 75mm</strong></td>
                  <td>R1.95 direct fix / R2.65 batten cavity</td>
                  <td>37 Rw (system incl. frame + 10mm gyprock)</td>
                  <td>$16–20</td>
                  <td>—</td>
                </tr>
                <tr>
                  <td><strong>NRG Greenboard — 100mm</strong></td>
                  <td>R2.60 direct fix / R3.31 batten cavity</td>
                  <td>39 Rw (system incl. frame + 10mm gyprock)</td>
                  <td>$19–25</td>
                  <td>1.79 kg</td>
                </tr>
                <tr>
                  <td><strong>Hebel PowerPanelXL — 75mm</strong></td>
                  <td>R0.52</td>
