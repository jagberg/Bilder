---
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<nav id="main-nav">
  <div class="container nav-inner">
    <ul class="nav-menu">
      <li class={isActive('/') && currentPath === '/' ? 'active' : ''}>
        <a href="/">Home</a>
      </li>

      <li class={`has-dropdown ${isActive('/budget') || isActive('/how-to-save') ? 'active' : ''}`}>
        <a href="/budget/">Budget</a>
        <ul class="dropdown">
          <li><a href="/budget/">Budget Overview</a></li>
          <li><a href="/how-to-save-on-costs/">How to Save on Costs</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/house-plans') || isActive('/knowing-what') || isActive('/builder-floorplan') || isActive('/architect-plans') || isActive('/tips-for-an-efficient') || isActive('/checking-your-plans') || isActive('/helpful-visualisation') ? 'active' : ''}`}>
        <a href="/house-plans/">House Plans</a>
        <ul class="dropdown">
          <li><a href="/house-plans/">House Plans Overview</a></li>
          <li><a href="/knowing-what-you-can-build/">Knowing What You Can Build</a></li>
          <li><a href="/builder-floorplan/">Builder Floorplan</a></li>
          <li><a href="/architect-plans/">Architect Plans</a></li>
          <li><a href="/tips-for-an-efficient-build-design/">Tips for an Efficient Build Design</a></li>
          <li><a href="/checking-your-plans/">Checking Your Plans</a></li>
          <li><a href="/helpful-visualisation-apps/">Helpful Visualisation Apps</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/choosing-a-builder') || isActive('/custom-or-project') || isActive('/what-to-do-before') || isActive('/comparing-pricing') ? 'active' : ''}`}>
        <a href="/choosing-a-builder/">Choosing a Builder</a>
        <ul class="dropdown">
          <li><a href="/choosing-a-builder/">Choosing a Builder</a></li>
          <li><a href="/custom-or-project-build/">Custom or Project Build</a></li>
          <li><a href="/what-to-do-before-paying-a-builder/">What to Do Before Paying a Builder</a></li>
          <li><a href="/comparing-pricing-for-tenders/">Comparing Pricing for Tenders</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/brick-cladding') || isActive('/windows') || isActive('/thermal-insulation') || isActive('/steel-or-timber') || isActive('/soundproofing') || isActive('/pools') || isActive('/structural-considerations') ? 'active' : ''}`}>
        <a href="/brick-cladding-hebel-or-otherwise/">Building Materials</a>
        <ul class="dropdown">
          <li><a href="/brick-cladding-hebel-or-otherwise/">Brick, Cladding, Hebel</a></li>
          <li><a href="/windows/">Windows</a></li>
          <li><a href="/thermal-insulation/">Thermal Insulation</a></li>
          <li><a href="/steel-or-timber-frame/">Steel or Timber Frame</a></li>
          <li><a href="/soundproofing/">Soundproofing</a></li>
          <li><a href="/pools/">Pools</a></li>
          <li><a href="/structural-considerations/">Structural Considerations</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/inclusions') || isActive('/electrical-plan') || isActive('/lighting-tips') || isActive('/staircase') || isActive('/builder-margin') ? 'active' : ''}`}>
        <a href="/inclusions/">Inclusions &amp; Options</a>
        <ul class="dropdown">
          <li><a href="/inclusions/">Builder Inclusions</a></li>
          <li><a href="/electrical-plan-and-home-automation/">Electrical &amp; Home Automation</a></li>
          <li><a href="/lighting-tips-and-ideas-for-a-new-home/">Lighting Tips</a></li>
          <li><a href="/staircase/">Staircase Options</a></li>
          <li><a href="/builder-margin-and-markup/">Builder Margin &amp; Markup</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/pre-construction-phase') || isActive('/demolition') ? 'active' : ''}`}>
        <a href="/pre-construction-phase/">Pre-Construction</a>
        <ul class="dropdown">
          <li><a href="/pre-construction-phase/">Pre-Construction Phase</a></li>
          <li><a href="/demolition/">Demolition</a></li>
        </ul>
      </li>

      <li class={`has-dropdown ${isActive('/construction-phases') || isActive('/quality-control') || isActive('/conflict-resolution') ? 'active' : ''}`}>
        <a href="/construction-phases/">Construction</a>
        <ul class="dropdown">
          <li><a href="/construction-phases/">Construction Phases</a></li>
          <li><a href="/quality-control/">Quality Control</a></li>
          <li><a href="/conflict-resolution/">Conflict Resolution</a></li>
