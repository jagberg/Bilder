---
const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}

const navGroups = [
  {
    label: 'Budget',
    href: '/budget/',
    children: [
      { label: 'Budget Overview', href: '/budget/' },
      { label: 'How to Save on Costs', href: '/how-to-save-on-costs/' },
      { label: 'Builder Margin and Markup', href: '/builder-margin-and-markup/' },
    ],
  },
  {
    label: 'House Plans',
    href: '/house-plans/',
    children: [
      { label: 'House Plans Overview', href: '/house-plans/' },
      { label: 'Knowing What You Can Build', href: '/knowing-what-you-can-build/' },
      { label: 'Builder Floorplan', href: '/builder-floorplan/' },
      { label: 'Architect Plans', href: '/architect-plans/' },
      { label: 'Tips for an Efficient Build Design', href: '/tips-for-an-efficient-build-design/' },
      { label: 'Checking Your Plans', href: '/checking-your-plans/' },
      { label: 'Helpful Visualisation Apps', href: '/helpful-visualisation-apps/' },
    ],
  },
  {
    label: 'Choosing a Builder',
    href: '/choosing-a-builder/',
    children: [
      { label: 'Choosing a Builder Overview', href: '/choosing-a-builder/' },
      { label: 'Custom or Project Build', href: '/custom-or-project-build/' },
      { label: 'What to Consider Before Paying a Builder', href: '/what-to-do-before-paying-a-builder/' },
      { label: 'Comparing Pricing of Tenders', href: '/comparing-pricing-for-tenders/' },
    ],
  },
  {
    label: 'Building Materials & Inclusions',
    href: '/brick-cladding-hebel-or-otherwise/',
    children: [
      { label: 'Brick, Cladding, Hebel or Otherwise', href: '/brick-cladding-hebel-or-otherwise/' },
      { label: 'Builder Inclusions and Selection Options', href: '/inclusions/' },
      { label: 'Electrical and Home Automation', href: '/electrical-plan-and-home-automation/' },
      { label: 'Lighting Tips and Ideas', href: '/lighting-tips-and-ideas-for-a-new-home/' },
      { label: 'Pools', href: '/pools/' },
      { label: 'Soundproofing', href: '/soundproofing/' },
      { label: 'Staircase Options', href: '/staircase/' },
      { label: 'Steel or Timber Frame', href: '/steel-or-timber-frame/' },
      { label: 'Structural Considerations', href: '/structural-considerations/' },
      { label: 'Thermal Insulation', href: '/thermal-insulation/' },
      { label: 'Windows', href: '/windows/' },
    ],
  },
  {
    label: 'Construction',
    href: '/pre-construction-phase/',
    children: [
      { label: 'Pre-Construction Phase', href: '/pre-construction-phase/' },
      { label: 'Demolishing a House', href: '/demolition/' },
      { label: 'Construction Phases', href: '/construction-phases/' },
      { label: 'Quality Control and Private Inspections', href: '/quality-control/' },
      { label: 'Conflict Resolution', href: '/conflict-resolution/' },
    ],
  },
  {
    label: 'Research and Tips',
    href: '/sources-of-information/',
    children: [
      { label: 'Sources of Information', href: '/sources-of-information/' },
      { label: 'Getting Inspiration', href: '/getting-inspiration/' },
      { label: 'Common Mistakes', href: '/common-mistakes/' },
    ],
  },
];
---

<!-- Desktop nav -->
<nav id="main-nav" role="navigation" aria-label="Main navigation">
  <div class="container nav-inner">
    <ul class="desktop-menu" role="list">
      <li class={isActive('/') && currentPath === '/' ? 'active' : ''}>
        <a href="/">Home</a>
      </li>
      {navGroups.map(group => {
        const groupActive = group.children.some(c => isActive(c.href));
        return (
          <li class={`has-dropdown${groupActive ? ' active' : ''}`}>
            <button class="dropdown-trigger" aria-expanded="false" aria-haspopup="true">
              {group.label}
              <svg class="chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul class="dropdown" role="list">
              {group.children.map(child => (
                <li class={isActive(child.href) ? 'active' : ''}>
                  <a href={child.href}>{child.label}</a>
                </li>
              ))}
            </ul>
          </li>
        );
      })}
      <li class={isActive('/about') ? 'active' : ''}>
        <a href="/about/">About</a>
      </li>
    </ul>
  </div>
</nav>

<!-- Mobile overlay -->
<div id="mobile-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Navigation menu">
  <div class="overlay-header">
    <a href="/" class="overlay-logo">
      <img src="/images/bilder-logo.png" alt="New Build Journey" height="44" />
    </a>
    <button id="mobile-close" aria-label="Close navigation">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <nav class="overlay-nav" aria-label="Mobile navigation">
    <ul role="list">
      <li>
        <a href="/" class={`overlay-link${isActive('/') && currentPath === '/' ? ' active' : ''}`}>Home</a>
      </li>

      {navGroups.map((group, i) => {
        const groupActive = group.children.some(c => isActive(c.href));
        return (
          <li class="overlay-group">
            <button
              class={`overlay-group-trigger${groupActive ? ' active' : ''}`}
              aria-expanded={groupActive ? 'true' : 'false'}
              data-group={i}
            >
              {group.label}
              <svg class="chevron" width="12" height="7" viewBox="0 0 12 7" fill="none" aria-hidden="true">
                <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <ul
              class={`overlay-children${groupActive ? ' open' : ''}`}
              aria-hidden={groupActive ? 'false' : 'true'}
              role="list"
            >
              {group.children.map(child => (
                <li>
                  <a href={child.href} class={`overlay-child-link${isActive(child.href) ? ' active' : ''}`}>
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        );
      })}

      <li>
        <a href="/about/" class={`overlay-link${isActive('/about') ? ' active' : ''}`}>About</a>
      </li>
    </ul>
  </nav>
</div>

<!-- Backdrop -->
<div id="nav-backdrop"></div>

<style>
  /* ── Desktop nav ── */
  #main-nav {
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    position: relative;
    z-index: 200;
  }

  .nav-inner {
    position: relative;
  }

  .desktop-menu {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    margin: 0;
    padding: 0;
  }

  .desktop-menu > li > a,
  .dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 13px 12px;
    color: #555;
    font-size: 0.82rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: color 0.15s;
    line-height: 1;
  }

  .desktop-menu > li > a:hover,
  .dropdown-trigger:hover,
  .desktop-menu > li.active > a,
  .desktop-menu > li.active .dropdown-trigger {
    color: #fd356f;
    text-decoration: none;
  }

  .dropdown-trigger .chevron {
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .has-dropdown:hover .dropdown-trigger .chevron {
    transform: rotate(180deg);
  }

  .has-dropdown {
    position: relative;
  }

  .dropdown {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    min-width: 260px;
    list-style: none;
    padding: 6px 0;
    margin: 0;
    border-radius: 8px;
    border: 1px solid #e8e8e8;
    border-top: 2px solid #fd356f;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.10);
    z-index: 300;
    transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }

  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .dropdown li a {
    display: block;
    padding: 9px 18px;
    color: #555;
    font-size: 0.82rem;
    text-decoration: none;
    transition: color 0.12s, background 0.12s;
  }

  .dropdown li a:hover,
  .dropdown li.active a {
    color: #fd356f;
    background: #fff5f8;
    text-decoration: none;
  }

  /* ── Mobile overlay ── */
  #mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: #fff;
    z-index: 600;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  #mobile-overlay.open {
    display: block;
    animation: overlayIn 0.22s ease;
  }

  @keyframes overlayIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .overlay-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #f0f0f0;
    position: sticky;
    top: 0;
    background: #fff;
    z-index: 1;
  }

  .overlay-logo img {
    display: block;
    height: 44px;
    width: auto;
  }

  #mobile-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    color: #333;
    border-radius: 50%;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  #mobile-close:hover {
    background: #f5f5f5;
  }

  .overlay-nav {
    padding: 8px 0 40px;
  }

  .overlay-nav > ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Direct links (Home, About) */
  .overlay-link {
    display: block;
    padding: 14px 20px;
    font-size: 0.95rem;
    font-weight: 500;
    color: #222;
    text-decoration: none;
    border-bottom: 1px solid #f4f4f4;
    transition: color 0.12s;
  }

  .overlay-link:hover,
  .overlay-link.active {
    color: #fd356f;
    text-decoration: none;
  }

  /* Group trigger */
  .overlay-group-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 14px 20px;
    font-size: 0.95rem;
    font-weight: 500;
    color: #222;
    background: none;
    border: none;
    border-bottom: 1px solid #f4f4f4;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color 0.12s;
  }

  .overlay-group-trigger:hover,
  .overlay-group-trigger.active {
    color: #fd356f;
  }

  .overlay-group-trigger[aria-expanded="true"] {
    color: #fd356f;
    border-bottom-color: transparent;
  }

  .overlay-group-trigger .chevron {
    flex-shrink: 0;
    transition: transform 0.22s ease;
    color: #999;
  }

  .overlay-group-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* Accordion — height driven by JS */
  .overlay-children {
    overflow: hidden;
    height: 0;
    transition: height 0.25s ease;
    background: #fafafa;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .overlay-child-link {
    display: block;
    padding: 11px 20px 11px 32px;
    font-size: 0.88rem;
    color: #555;
    text-decoration: none;
    border-bottom: 1px solid #efefef;
    transition: color 0.12s;
  }

  .overlay-children li:last-child .overlay-child-link {
    border-bottom: 1px solid #f4f4f4;
  }

  .overlay-child-link:hover,
  .overlay-child-link.active {
    color: #fd356f;
    text-decoration: none;
  }

  /* Backdrop */
  #nav-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 590;
    backdrop-filter: blur(2px);
  }

  #nav-backdrop.visible {
    display: block;
    animation: backdropIn 0.2s ease;
  }

  @keyframes backdropIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (min-width: 901px) {
    #mobile-overlay,
    #nav-backdrop {
      display: none !important;
    }
  }

  @media (max-width: 900px) {
    #main-nav {
      display: none;
    }
  }
</style>

<script>
  // ── Overlay open/close ──
  const toggle   = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const closeBtn = document.getElementById('mobile-close') as HTMLButtonElement | null;
  const overlay  = document.getElementById('mobile-overlay') as HTMLElement | null;
  const backdrop = document.getElementById('nav-backdrop') as HTMLElement | null;

  function openMenu() {
    overlay?.classList.add('open');
    backdrop?.classList.add('visible');
    overlay?.removeAttribute('aria-hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    overlay?.classList.remove('open');
    backdrop?.classList.remove('visible');
    overlay?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', () => {
    overlay?.classList.contains('open') ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeMenu();
  });

  // Close overlay when any link inside it is clicked
  overlay?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // ── Accordion ──
  function setHeight(el: HTMLElement, open: boolean) {
    if (open) {
      el.style.height = el.scrollHeight + 'px';
    } else {
      // Animate from current rendered height down to 0
      el.style.height = el.scrollHeight + 'px';
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          el.style.height = '0';
        });
      });
    }
  }

  // Initialise heights for any groups that start open (active page)
  document.querySelectorAll<HTMLElement>('.overlay-children').forEach(el => {
    if (el.classList.contains('open') ||
        el.previousElementSibling?.getAttribute('aria-expanded') === 'true') {
      el.style.height = el.scrollHeight + 'px';
    } else {
      el.style.height = '0';
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.overlay-group-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const isExpanded = btn.getAttribute('aria-expanded') === 'true';
      const children = btn.nextElementSibling as HTMLElement | null;

      // Collapse all other groups
      document.querySelectorAll<HTMLButtonElement>('.overlay-group-trigger').forEach(other => {
        if (other !== btn && other.getAttribute('aria-expanded') === 'true') {
          other.setAttribute('aria-expanded', 'false');
          const otherChildren = other.nextElementSibling as HTMLElement | null;
          if (otherChildren) setHeight(otherChildren, false);
        }
      });

      // Toggle this group
      const next = !isExpanded;
      btn.setAttribute('aria-expanded', String(next));
      if (children) setHeight(children, next);
    });
  });
</script>
